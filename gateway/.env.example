# Gateway Environment Variables

# Required: Session secret for express-session (generate with: openssl rand -hex 32)
SESSION_SECRET=your-session-secret-here

# Optional: Default admin account (if not set, admin won't be auto-created)
GATEWAY_ADMIN_EMAIL=admin@example.com
GATEWAY_ADMIN_PASSWORD=your-secure-password
GATEWAY_ADMIN_NAME=관리자

# Optional: Server port (default: 8080)
# PORT=8080
