# ===========================================
# @TASK T6.3 - Docker Environment Variables
# Copy this file to .env.docker and fill in values
# ===========================================

# --- Server ---
NODE_ENV=production
PORT=5000
FRONTEND_PORT=8080

# --- Database ---
DATABASE_PATH=./data/travel.db

# --- Authentication ---
# Required: Set a strong admin password
ADMIN_PASSWORD=changeme

# Required: Random string for session encryption
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:8080

# --- External Services ---
# Gemini API key for passport OCR (optional)
GEMINI_API_KEY=

# Landing server URL for passport OCR proxy (optional)
LANDING_API_URL=http://localhost:5505

# --- Email Notifications (optional) ---
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# NOTIFY_EMAIL=
