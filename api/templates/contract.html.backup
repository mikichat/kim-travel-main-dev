{% extends "base.html" %}

{% block title %}계약서 - {{ group.name }}{% endblock %}
{% block document_title %}여행 계약서{% endblock %}

{% block content %}
<div class="section">
    <h2 class="section-title">단체 기본 정보</h2>
    <div class="info-grid">
        <div class="info-item">
            <span class="info-label">단체명:</span>
            <span class="info-value">{{ group.name }}</span>
        </div>
        <div class="info-item">
            <span class="info-label">여행 기간:</span>
            <span class="info-value">{{ group.nights }}박 {{ group.days }}일</span>
        </div>
        <div class="info-item">
            <span class="info-label">출발일:</span>
            <span class="info-value">{{ group.start_date|format_date }}</span>
        </div>
        <div class="info-item">
            <span class="info-label">도착일:</span>
            <span class="info-value">{{ group.end_date|format_date }}</span>
        </div>
        <div class="info-item">
            <span class="info-label">인원:</span>
            <span class="info-value">{{ group.pax }}명</span>
        </div>
        <div class="info-item">
            <span class="info-label">계약 상태:</span>
            <span class="info-value">
                {% if group.status == 'contract' %}계약 완료
                {% elif group.status == 'confirmed' %}확정
                {% else %}미계약
                {% endif %}
            </span>
        </div>
    </div>
</div>

<div class="section">
    <h2 class="section-title">계약 금액</h2>
    <table>
        <thead>
            <tr>
                <th>항목</th>
                <th style="text-align: right;">금액</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>1인당 요금</td>
                <td style="text-align: right;">{{ group.price_per_pax|format_currency }}</td>
            </tr>
            <tr>
                <td>총 인원</td>
                <td style="text-align: right;">{{ group.pax }}명</td>
            </tr>
            <tr style="background-color: #f9fafb; font-weight: bold;">
                <td>총 계약 금액</td>
                <td style="text-align: right;">{{ group.total_price|format_currency }}</td>
            </tr>
            <tr>
                <td>계약금 (선납)</td>
                <td style="text-align: right;">{{ group.deposit|format_currency }}</td>
            </tr>
            <tr style="background-color: #f3f4f6; font-weight: bold;">
                <td>잔액</td>
                <td style="text-align: right;">{{ group.balance|format_currency }}</td>
            </tr>
            {% if group.balance_due_date %}
            <tr>
                <td>잔액 완납일</td>
                <td style="text-align: right; color: #DC2626; font-weight: bold;">{{ group.balance_due_date|format_date }}</td>
            </tr>
            {% endif %}
        </tbody>
    </table>
</div>

{% if cancel_rules %}
<div class="section">
    <h2 class="section-title">취소 수수료 및 환불 규정</h2>
    <table>
        <thead>
            <tr>
                <th style="width: 150px;">취소 시점</th>
                <th style="width: 120px;">취소 기준일</th>
                <th style="text-align: right;">위약금 비율</th>
                <th>비고</th>
            </tr>
        </thead>
        <tbody>
            {% for rule in cancel_rules %}
            <tr>
                <td>출발 {{ rule.days_before }}일 전</td>
                <td>{{ rule.cancel_date|format_date('%m/%d') }}</td>
                <td style="text-align: right; font-weight: bold;">{{ rule.penalty_rate }}%</td>
                <td>{{ rule.description or '-' }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <div style="margin-top: 15px; padding: 12px; background-color: #FEF3C7; border-left: 3px solid #F59E0B;">
        <p style="margin: 0; font-size: 10pt; color: #92400E;">
            <strong>※ 취소 규정 안내</strong><br>
            - 위약금은 여행 출발일을 기준으로 적용됩니다.<br>
            - 당일 취소 또는 No-Show의 경우 환불이 불가능합니다.<br>
            - 천재지변 등 불가항력적인 사유의 경우 별도 협의합니다.
        </p>
    </div>
</div>
{% endif %}

{% if includes %}
<div class="section">
    <h2 class="section-title">여행 포함 사항</h2>

    {% set included_items = includes|selectattr('item_type', 'equalto', 'include')|list %}
    {% if included_items %}
    <div style="margin-bottom: 20px;">
        <h3 style="color: #10B981; font-size: 12pt; margin-bottom: 10px;">✓ 포함 사항</h3>
        <ul style="margin: 0; padding-left: 25px; line-height: 1.8;">
            {% for item in included_items|sort(attribute='display_order') %}
            <li>{{ item.description }}</li>
            {% endfor %}
        </ul>
    </div>
    {% endif %}

    {% set excluded_items = includes|selectattr('item_type', 'equalto', 'exclude')|list %}
    {% if excluded_items %}
    <div>
        <h3 style="color: #EF4444; font-size: 12pt; margin-bottom: 10px;">✗ 불포함 사항</h3>
        <ul style="margin: 0; padding-left: 25px; line-height: 1.8;">
            {% for item in excluded_items|sort(attribute='display_order') %}
            <li>{{ item.description }}</li>
            {% endfor %}
        </ul>
    </div>
    {% endif %}
</div>
{% endif %}

<div class="section">
    <h2 class="section-title">계약 조건</h2>
    <div style="line-height: 1.8; font-size: 10pt;">
        <p><strong>제1조 (계약의 성립)</strong></p>
        <p style="margin-left: 20px;">
            본 계약은 여행자가 계약금을 지불하고 여행사가 이를 승인함으로써 성립됩니다.
        </p>

        <p><strong>제2조 (여행 요금)</strong></p>
        <p style="margin-left: 20px;">
            1. 여행 요금은 위에 명시된 금액을 기준으로 합니다.<br>
            2. 계약금은 총 요금의 일부이며, 잔금은 {{ group.balance_due_date|format_date if group.balance_due_date else '출발 7일 전' }}까지 완납해야 합니다.
        </p>

        <p><strong>제3조 (취소 및 환불)</strong></p>
        <p style="margin-left: 20px;">
            1. 여행 계약의 취소 시 상기 취소 수수료 규정에 따라 위약금이 부과됩니다.<br>
            2. 여행사의 귀책 사유로 여행이 취소될 경우 전액 환불됩니다.
        </p>

        <p><strong>제4조 (여행사의 의무)</strong></p>
        <p style="margin-left: 20px;">
            1. 여행사는 계약서에 명시된 여행 일정과 서비스를 제공해야 합니다.<br>
            2. 불가피한 사정으로 일정 변경이 필요한 경우 사전에 여행자에게 통보해야 합니다.
        </p>

        <p><strong>제5조 (여행자의 의무)</strong></p>
        <p style="margin-left: 20px;">
            1. 여행자는 여권, 비자 등 여행에 필요한 서류를 준비해야 합니다.<br>
            2. 단체 여행의 원활한 진행을 위해 인솔자의 안내에 협조해야 합니다.
        </p>

        <p><strong>제6조 (분쟁 해결)</strong></p>
        <p style="margin-left: 20px;">
            본 계약과 관련된 분쟁은 관련 법령 및 일반 관례에 따라 해결합니다.
        </p>
    </div>
</div>

<div class="section" style="margin-top: 40px; border-top: 2px solid #ddd; padding-top: 30px;">
    <h2 class="section-title">계약 당사자</h2>
    <table style="border: none;">
        <tr style="border: none;">
            <td style="border: none; width: 50%; padding: 20px; vertical-align: top;">
                <p style="font-weight: bold; margin-bottom: 15px;">여행사</p>
                <p style="line-height: 2;">
                    상호: ___________________________<br>
                    대표: ___________________________<br>
                    주소: ___________________________<br>
                    연락처: _________________________<br>
                    <br>
                    서명: ___________________________(인)
                </p>
            </td>
            <td style="border: none; width: 50%; padding: 20px; vertical-align: top;">
                <p style="font-weight: bold; margin-bottom: 15px;">여행자 (단체 대표)</p>
                <p style="line-height: 2;">
                    단체명: {{ group.name }}<br>
                    대표자: _________________________<br>
                    주소: ___________________________<br>
                    연락처: _________________________<br>
                    <br>
                    서명: ___________________________(인)
                </p>
            </td>
        </tr>
    </table>
</div>

<div class="section" style="margin-top: 30px; padding: 15px; background-color: #F3F4F6; border-left: 3px solid #2563EB;">
    <p style="margin: 0; font-size: 10pt; color: #666; text-align: center;">
        본 계약서는 {{ generated_date|format_date }}에 작성되었으며,<br>
        상기 내용에 동의하여 쌍방이 서명 날인합니다.
    </p>
</div>
{% endblock %}
