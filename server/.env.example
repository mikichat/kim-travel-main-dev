# TourWorld Server Configuration
# Copy this file to .env and update values

# ===========================================
# SERVER
# ===========================================
NODE_ENV=development
PORT=3001

# ===========================================
# DATABASE (SQLite)
# ===========================================
DATABASE_URL=./data/tourworld.db

# ===========================================
# JWT AUTHENTICATION
# ===========================================
# Generate secure keys with: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===========================================
# ADMIN USER
# ===========================================
ADMIN_EMAIL=admin@tourworld.com
ADMIN_PASSWORD=change-this-in-production
ADMIN_NAME=관리자

# ===========================================
# CORS (comma-separated)
# ===========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ===========================================
# RATE LIMITING
# ===========================================
# Window in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
# Max requests per window (default: 100)
RATE_LIMIT_MAX=100
# Max auth requests per window (default: 10)
RATE_LIMIT_AUTH_MAX=10

# ===========================================
# SECURITY NOTES
# ===========================================
# 1. Always change JWT_SECRET in production
# 2. Use strong passwords for admin account
# 3. Update CORS_ORIGINS with your production domain
# 4. Enable HTTPS in production (NODE_ENV=production)
