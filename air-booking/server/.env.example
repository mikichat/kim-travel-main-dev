# Air-Booking 서버 환경변수 (필수)
# .env 파일로 복사 후 값을 설정하세요: cp .env.example .env

# 암호화 키 (64자 hex) — 여권번호 등 개인정보 암호화에 사용
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# 세션 시크릿 — 로그인 세션 관리에 사용
# 생성: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET=

# CORS 허용 도메인 (쉼표 구분)
CORS_ORIGINS=http://192.168.0.15:5174

# 서버 포트 (기본: 5510)
PORT=5510
