# ===========================================
# Backend Environment Variables
# Copy this file to .env and fill in the values
# ===========================================

# Server
PORT=5000
NODE_ENV=development

# Database
DATABASE_PATH=./travel_agency.db

# Session
SESSION_SECRET=your-session-secret-here

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:4005

# Gemini AI (for OCR/document parsing)
GEMINI_API_KEY=your-gemini-api-key

# Email Notifications (Gmail SMTP)
NOTIFY_EMAIL=your-email@gmail.com
NOTIFY_EMAIL_PASS=your-app-password
NOTIFY_EMAIL_TO=recipient@gmail.com

# Kakao Notifications (optional)
KAKAO_ACCESS_TOKEN=

# OpenAI (optional)
OPENAI_API_KEY=

# OCR Server (optional)
OCR_SERVER_URL=http://localhost:5505

# App URL (for notification links)
APP_URL=http://localhost:5000
