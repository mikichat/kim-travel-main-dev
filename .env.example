# ===========================================
# TourWorld Development Environment Variables
# ===========================================
# Copy this file to .env and update the values
# cp .env.example .env

# -------------------------------------------
# PostgreSQL Database (with PGVector)
# -------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tourworld
POSTGRES_PORT=5432

# Database connection URL (for Prisma)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tourworld

# -------------------------------------------
# Server Configuration
# -------------------------------------------
NODE_ENV=development
SERVER_PORT=3001

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# -------------------------------------------
# Client Configuration
# -------------------------------------------
CLIENT_PORT=5173
VITE_API_URL=http://localhost:3001

# -------------------------------------------
# pgAdmin (Development Only)
# -------------------------------------------
PGADMIN_EMAIL=admin@tourworld.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# -------------------------------------------
# Optional: AI/Embedding Services
# -------------------------------------------
# OPENAI_API_KEY=sk-your-openai-api-key
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSION=1536
